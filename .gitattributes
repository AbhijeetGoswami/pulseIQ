# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python files should use LF
*.py text eol=lf

# Documentation files
*.md text eol=lf
*.txt text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
