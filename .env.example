# PulseIQ API Configuration Example
# Copy this to .env and adjust values as needed

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
DEBUG=False

# Application
APP_NAME=PulseIQ
APP_VERSION=1.0.0

# CORS Settings
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ORIGINS=*

# Database
# DB_PATH is set in config.py relative to BASE_DIR
# DB_PATH=./data/pulseiq.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/api.log
